{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities for the main UniSSH window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-unmaximize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-set-title",
    "core:webview:default",
    "core:event:default",
    "os:default",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-text",
    "clipboard-manager:allow-clear",
    "store:default",
    "dialog:default",
    "opener:default",
    "log:default",
    "fs:default",
    { "identifier": "fs:allow-read-dir", "allow": [{ "path": "$HOME" }, { "path": "$HOME/**" }, { "path": "$HOME/.ssh" }, { "path": "$HOME/.ssh/**" }] },
    { "identifier": "fs:allow-read-file", "allow": [{ "path": "$HOME/**" }, { "path": "$HOME/.ssh/**" }] },
    { "identifier": "fs:allow-read-text-file", "allow": [{ "path": "$HOME/**" }, { "path": "$HOME/.ssh/**" }] },
    { "identifier": "fs:allow-write-file", "allow": [{ "path": "$HOME/**" }] },
    { "identifier": "fs:allow-write-text-file", "allow": [{ "path": "$HOME/**" }] },
    { "identifier": "fs:allow-stat", "allow": [{ "path": "$HOME" }, { "path": "$HOME/**" }, { "path": "$HOME/.ssh" }, { "path": "$HOME/.ssh/**" }] },
    { "identifier": "fs:allow-exists", "allow": [{ "path": "$HOME" }, { "path": "$HOME/**" }, { "path": "$HOME/.ssh" }, { "path": "$HOME/.ssh/**" }] },
    { "identifier": "fs:allow-mkdir", "allow": [{ "path": "$HOME/**" }] },
    { "identifier": "fs:allow-rename", "allow": [{ "path": "$HOME/**" }] },
    { "identifier": "fs:allow-remove", "allow": [{ "path": "$HOME" }, { "path": "$HOME/**" }] },
    { "identifier": "fs:allow-copy-file", "allow": [{ "path": "$HOME/**" }] }
  ]
}
