---
import Icon from './Icon.astro';
/**
 * Hero visual: a Nebula-themed faux terminal showing the real
 * rust-core CLI end-to-end flow (init -> create-vault -> gen-key
 * -> exec --jump), overlaid with an encrypted-vault card whose
 * item rows render as cipher-byte strings.
 */
---

<div class="hero__visual">
  <div class="term" role="img" aria-label="UniSSH CLI: init, create-vault, gen-key and exec over a ProxyJump bastion">
    <div class="term__bar">
      <span class="term__lights" aria-hidden="true">
        <span class="term__light" style="background:#ff5f57"></span>
        <span class="term__light" style="background:#febc2e"></span>
        <span class="term__light" style="background:#28c840"></span>
      </span>
      <span class="term__title">unissh — zsh</span>
    </div>
    <div class="term__body">
      <div class="term__line"><span class="t-prompt">$</span> <span class="t-cmd">unissh init</span> <span class="t-flag">--password</span> <span class="t-str">pw</span></div>
      <div class="term__line"><span class="t-out">Secret Key (Emergency Kit):</span> <span class="t-str">A3-XK29-7FQ2-...-9JZ</span></div>
      <div class="term__line"><span class="t-prompt">$</span> <span class="t-cmd">unissh create-vault</span> <span class="t-flag">--id</span> <span class="t-str">default</span> <span class="t-flag">--name</span> <span class="t-str">Default</span></div>
      <div class="term__line"><span class="t-ok">✓</span> <span class="t-out">vault sealed · Vault Key wrapped</span></div>
      <div class="term__line"><span class="t-prompt">$</span> <span class="t-cmd">unissh gen-key</span> <span class="t-flag">--vault</span> <span class="t-str">default</span> <span class="t-flag">--item</span> <span class="t-str">id_ed25519</span></div>
      <div class="term__line"><span class="t-ok">✓</span> <span class="t-out">ed25519 generated · private key never leaves the agent</span></div>
      <div class="term__line"><span class="t-prompt">$</span> <span class="t-cmd">unissh exec</span> <span class="t-flag">--host</span> <span class="t-str">10.0.0.5</span> <span class="t-flag">--user</span> <span class="t-str">deploy</span> \</div>
      <div class="term__line">    <span class="t-flag">--jump</span> <span class="t-str">bastion:22:admin:id_ed25519</span> <span class="t-flag">--command</span> <span class="t-str">"uname -a"</span></div>
      <div class="term__line"><span class="t-out">Linux web-01 6.8.0 #1 SMP x86_64 GNU/Linux</span><span class="cursor" aria-hidden="true"></span></div>
    </div>
  </div>

  <aside class="glass vault" aria-label="Encrypted vault contents">
    <div class="vault__head">
      <span class="vault__lock" aria-hidden="true">
        <Icon name="lock" size={18} stroke={1.8} />
      </span>
      <div>
        <div class="vault__title">Default vault</div>
        <div class="vault__sub">zero-knowledge · sealed</div>
      </div>
    </div>

    <div class="vault__row">
      <Icon name="key" size={16} />
      <div class="vault__rowmeta">
        <div class="vault__label">SSH key · id_ed25519</div>
        <div class="vault__cipher">9f2c·a71e·44b0·c8d3·1e6a</div>
      </div>
    </div>
    <div class="vault__row">
      <Icon name="globe" size={16} />
      <div class="vault__rowmeta">
        <div class="vault__label">Host profile · web-01</div>
        <div class="vault__cipher">5b8c·ff3a·d291·0e74·bb2f</div>
      </div>
    </div>
    <div class="vault__row">
      <Icon name="lock" size={16} />
      <div class="vault__rowmeta">
        <div class="vault__label">Password · deploy@db</div>
        <div class="vault__cipher">c401·9aa7·2f5d·68e1·73c9</div>
      </div>
    </div>
  </aside>
</div>
