---
import Icon from './Icon.astro';

interface Props {
  securityHref: string;
}
const { securityHref } = Astro.props;

const claims = [
  {
    title: 'XChaCha20-Poly1305 AEAD',
    desc: 'with associated data binding vault_id, item_id and version.',
  },
  {
    title: 'Argon2id KDF',
    desc: 'derives the Unlock Key from your passphrase.',
  },
  {
    title: 'HPKE / X25519 wrapping',
    desc: 'wraps per-item and vault keys for sharing.',
  },
  {
    title: 'Ed25519 signed versions',
    desc: 'monotonic and anti-rollback, with tombstones.',
  },
  {
    title: 'In-memory SSH agent',
    desc: 'mlock + zeroize; private keys never hit disk.',
  },
  {
    title: 'ProxyJump over the agent',
    desc: 'chained bastions, no agent-forwarding by default.',
  },
  {
    title: 'Append-only audit log',
    desc: 'server-side SHA-256 hash chain, tamper-evident.',
  },
  {
    title: 'Verify-before-apply sync',
    desc: 'highest signed version wins; conflicts surfaced, never silently merged.',
  },
];
---

<section class="security" id="security" aria-labelledby="security-head">
  <div class="wrap">
    <div class="glass security__band reveal">
      <div class="section-head" style="margin-bottom:0;max-width:680px;">
        <span class="eyebrow">SECURITY MODEL</span>
        <h2 id="security-head">We don't roll our own crypto</h2>
      </div>

      <div class="security__claims">
        {
          claims.map((c) => (
            <div class="claim">
              <span class="claim__icon" aria-hidden="true">
                <Icon name="check" size={18} stroke={2} />
              </span>
              <div>
                <div class="claim__title">{c.title}</div>
                <div class="claim__desc">{c.desc}</div>
              </div>
            </div>
          ))
        }
      </div>

      <p class="security__foot">
        Built on RustCrypto, <code>hpke</code> and SQLCipher —
        <a class="grad-text" href={securityHref} style="font-weight:600;">read the zero-knowledge model &rarr;</a>
      </p>
    </div>
  </div>
</section>
