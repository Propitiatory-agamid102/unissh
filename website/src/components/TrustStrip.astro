---
const pillars = [
  {
    n: '01',
    title: 'An untrusted ciphertext store',
    body:
      'The server performs no payload crypto by design — only TLS 1.3 and Ed25519 signature verification for auth and registration. A database dump gives an attacker only ciphertext.',
  },
  {
    n: '02',
    title: 'Keys never leave your device',
    body:
      'Your Secret Key is generated locally and your private keyset is never uploaded. The core hands the UI public keys and fingerprints — never plaintext private keys.',
  },
  {
    n: '03',
    title: 'Honest about metadata',
    body:
      'Content, including item names, is always encrypted. The social graph, blob sizes and sync timings are visible by design — and documented, not hidden.',
  },
];
---

<section class="trust" aria-labelledby="trust-lead">
  <div class="wrap">
    <div class="glass trust__band reveal">
      <div class="trust__tagrow">
        <span class="mono-tag is-green">zero-knowledge (E2EE)</span>
      </div>
      <p class="trust__lead" id="trust-lead">
        A database dump gives an attacker only <span class="grad-text-2">ciphertext</span>.
      </p>
      <div class="trust__pillars">
        {
          pillars.map((p) => (
            <div class="pillar">
              <div class="pillar__n">{p.n}</div>
              <h3>{p.title}</h3>
              <p>{p.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
